#!name=2026世界杯数据面板
#!desc=FIFA 2026美加墨世界杯：赛程/比分/分组/射手/通知，48队104场完整数据
#!author=GitHubWBB
#!category=GitHubWBB
#!icon=https://raw.githubusercontent.com/Koolson/Qure/master/IconSet/Color/FIFA.png
#!system=ios
#!arguments=api_key:22c9843b0896497eb6ca3e77b78cf5fe,remind_before:30
#!arguments-desc=api_key: football-data.org API Key\nremind_before: 赛前提醒提前分钟数 (默认30)

[Panel]
今日赛程 = script-name=worldcup-today, update-interval=120
实时比分 = script-name=worldcup-live, update-interval=60
分组详情 = script-name=worldcup-groups, update-interval=300
射手榜 = script-name=worldcup-scorers, update-interval=600

[Script]
worldcup-today = type=generic, script-path=https://raw.githubusercontent.com/GitHubWBB/Surge/main/fifa2026/worldcup_today.js, timeout=30, argument=api_key={{{api_key}}}
worldcup-live = type=generic, script-path=https://raw.githubusercontent.com/GitHubWBB/Surge/main/fifa2026/worldcup_live.js, timeout=30, argument=api_key={{{api_key}}}
worldcup-groups = type=generic, script-path=https://raw.githubusercontent.com/GitHubWBB/Surge/main/fifa2026/worldcup_groups.js, timeout=30, argument=api_key={{{api_key}}}
worldcup-scorers = type=generic, script-path=https://raw.githubusercontent.com/GitHubWBB/Surge/main/fifa2026/worldcup_scorers.js, timeout=30, argument=api_key={{{api_key}}}
世界杯通知 = type=cron, cronexp="*/10 * * * *", script-path=https://raw.githubusercontent.com/GitHubWBB/Surge/main/fifa2026/worldcup_notify.js, wake-system=1, timeout=30, argument=api_key={{{api_key}}}&remind_before={{{remind_before}}}

#!MANAGED-CONFIG https://raw.githubusercontent.com/GitHubWBB/Surge/main/fifa2026/2026_WorldCup_Dashboard.sgmodule interval=86400 strict=false
